<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>{{ title or site.title }}</title>
  <meta name="description" content="{{ description or site.description }}" />

  <!-- favicon -->
  <link rel="icon" href="/assets/favicon.ico" />

  <!-- google verification -->
  <meta name="google-site-verification" content="h-yyPjBd2taU2XTVFACfgQ9tqRL193o2vjicyY8_UmI" />

  <!-- css -->
  <link rel="stylesheet" href="/assets/style.css" />
</head>

<body>

<header class="site-header">
  <div class="container header-inner">

    <a href="/" class="logo">
      <img src="/assets/favicon.ico" class="logo-icon" alt="Alpha Coin Report" />
      <span>Alpha Coin Report</span>
    </a>

    <nav class="nav">
      <a href="/">Home</a>
      <a href="/reports/">Reports</a>
    </nav>

    <a
      class="header-binance-btn"
      href="https://www.binance.com/join?ref=XETYHXNR"
      target="_blank"
      rel="noopener noreferrer"
    >
      Open Binance
    </a>

  </div>
</header>

<main class="site-main">
  <div class="container">
    {{ content | safe }}
  </div>
</main>

<footer class="site-footer">
  <div class="container">

    <div class="footer-links">
      <a href="/privacy/">Privacy Policy</a>
      <a href="/disclaimer/">Disclaimer</a>
      <a href="/affiliate-disclosure/">Affiliate Disclosure</a>
    </div>

    <p class="footer-copy">
      © Alpha Coin Report. Informational purposes only. Not financial advice.
    </p>

  </div>
</footer>

</body>
</html>
